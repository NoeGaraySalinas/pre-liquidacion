{
  "name": "pre-liquidacion",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Sistema de pre-liquidación de servicios",
  "author": "Noelia Garay Salinas",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "html-to-docx": "^1.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.corsacor.preliquidacion",
    "productName": "Pre-Liquidación",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.json",
      "!**/*.map",
      "!**/*.md",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}"
    ],
    "extraResources": [
      "clientes.json",
      "servicios.json",
      "facturantes.json",
      "facturacion.json",
      "gastosInternos.json",
      "insumos.json",
      "aumentos.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
